{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema=src/db/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/db/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/db/schema.prisma",
    "prisma:seed": "tsx src/db/seed.ts",
    "prisma:reset": "prisma migrate reset --schema=src/db/schema.prisma",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@prisma/client": "^6.19.3",
    "express": "^5.2.1",
    "prisma": "^6.19.3",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "nodemon": "^3.1.14",
    "tsx": "^4.23.0"
  }
}
